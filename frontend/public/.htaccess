# =============================================================================
# Hostinger / Apache ONLY — NOT used by Cloudflare Pages
# After npm run build: copy dist/htaccess-hostinger.txt → public_html/.htaccess
# =============================================================================

Options -Indexes
DirectoryIndex index.html

# MIME types only (do NOT use mod_headers Content-Type — causes duplicate/wrong headers)
<IfModule mod_mime.c>
  AddType text/css              .css
  AddType application/javascript .js .mjs
  AddType image/svg+xml         .svg
  AddType image/png             .png
  AddType image/jpeg            .jpg .jpeg
  AddType image/webp            .webp
  AddType font/woff2            .woff2
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files & folders (assets/, logo.png, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # PHP backend — do not route to React
  RewriteRule ^backend/ - [L]

  # React SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>
